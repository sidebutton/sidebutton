{
  "name": "@sidebutton/server",
  "version": "1.1.2",
  "mcpName": "io.github.sidebutton/sidebutton",
  "description": "SideButton MCP server for AI agents — REST API, web dashboard, knowledge packs, and workflow engine",
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "ai-agents",
    "knowledge-packs",
    "workflow",
    "automation",
    "browser-automation",
    "chrome-extension",
    "claude-code",
    "cursor",
    "open-source"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "sidebutton": "./bin/sidebutton.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cli": "./dist/cli.js"
  },
  "files": [
    "dist",
    "bin",
    "dashboard",
    "defaults"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sidebutton/sidebutton.git",
    "directory": "packages/server"
  },
  "homepage": "https://sidebutton.com",
  "bugs": {
    "url": "https://github.com/sidebutton/sidebutton/issues"
  },
  "scripts": {
    "build": "tsup && pnpm run build:dashboard",
    "build:server": "tsup",
    "build:dashboard": "cd ../dashboard && pnpm build",
    "dev": "node --import tsx --watch-path=./src src/cli.ts serve",
    "dev:build": "tsup --watch",
    "start": "node bin/sidebutton.js serve",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/static": "^9.1.0",
    "@fastify/websocket": "^11.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sentry/node": "^10.48.0",
    "@sentry/profiling-node": "^10.48.0",
    "@sidebutton/core": "workspace:*",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dotenv": "^17.4.1",
    "fastify": "^5.8.4",
    "js-yaml": "^4.1.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.7.0",
    "@types/ws": "^8.18.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
